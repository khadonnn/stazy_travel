# .env.vps - VPS Deployment Environment Variables
# ⚠️ CRITICAL: This is for BACKEND only (running on VPS inside Docker)
# Frontend (Vercel) has its OWN .env file - see section 6 below

# ============================================================================
# 1. DATABASE & CACHE (Use container names, NOT localhost!)
# ============================================================================
# ⚠️ IMPORTANT: Inside Docker containers, localhost doesn't exist!
# Must use container names defined in docker-compose.yml

# PostgreSQL - use container name "postgres"
DATABASE_URL=postgresql://admin:123456@postgres:5432/products

# MongoDB - use container name "mongo" (if using Docker) or Atlas URI
MONGODB_URI=mongodb://mongo:27017/bookings

# Redis - use container name "redis"
REDIS_HOST=redis
REDIS_PORT=6379
# Optional if Redis requires password
REDIS_PASSWORD=

# ============================================================================
# 2. KAFKA (Optimized for 2GB RAM VPS - Single Broker Only!)
# ============================================================================
# ⚠️ VPS chỉ chạy 1 broker, không phải 3
KAFKA_BROKERS=kafka-broker-1:9092

# ============================================================================
# 3. INTERNAL SERVICE COMMUNICATION (Microservices → Microservices)
# ============================================================================
# ⚠️ Use container names, NOT localhost!
# These are for services calling each other INSIDE Docker network

PORT=8000
PRODUCT_SERVICE_URL=http://product-service:8000
BOOKING_SERVICE_URL=http://booking-service:8001
PAYMENT_SERVICE_URL=http://payment-service:8002
SEARCH_SERVICE_URL=http://search-service:8008
SOCKET_SERVICE_URL=http://socket-service:3005

# ============================================================================
# 4. EXTERNAL/PUBLIC COMMUNICATION (Outside Docker)
# ============================================================================
# URL nhật thật của VPS (domain hoặc IP) - dùng cho Stripe Webhook
VPS_PUBLIC_URL=https://your-domain.com
# Or if no domain yet: VPS_PUBLIC_URL=https://YOUR.VPS.IP.ADDRESS

# ============================================================================
# 5. THIRD-PARTY CREDENTIALS (Backend secrets)
# ============================================================================

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Cloudinary Image Hosting
CLOUDINARY_API_KEY=xxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxx

# ============================================================================
# 6. ENVIRONMENT MODE
# ============================================================================
NODE_ENV=production

# ============================================================================
# 7. LOGGING
# ============================================================================
LOG_LEVEL=info  # debug, info, warn, error

# ============================================================================
# ============================================================================
# ⚠️ FRONTEND (Next.js on Vercel) - SEPARATE .env FILE
# ============================================================================
# ✅ DO NOT include these in VPS .env
# ✅ These go into Vercel Dashboard → Settings → Environment Variables
# ============================================================================

# Clerk (Public key only - safe to expose)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Cloudinary (Public config)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# API URLs from VPS (Must use REAL domain/IP, NOT localhost!)
# NEXT_PUBLIC_PRODUCT_SERVICE_URL=https://your-domain.com/api/product
# NEXT_PUBLIC_BOOKING_SERVICE_URL=https://your-domain.com/api/booking
# NEXT_PUBLIC_PAYMENT_SERVICE_URL=https://your-domain.com/api/payment
# NEXT_PUBLIC_SEARCH_SERVICE_URL=https://your-domain.com/api/search
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
# 1. Copy this to .env.vps on VPS
# 2. Update values marked with "xxx"
# 3. For Vercel Frontend: Create separate .env.local with NEXT_PUBLIC_* vars
# 4. Test with: docker-compose config (check if it loads env correctly)
# 5. Never commit this file to Git - add .env.vps to .gitignore!
